{
  "name": "octometrics-action",
  "description": "Use octometrics in your GitHub Actions workflows to visualize and monitor your workflow's timing, CPU, memory, disk, IO, and more.",
  "version": "0.0.1",
  "author": "kalverra",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/kalverra/octometrics-action#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalverra/octometrics-action.git"
  },
  "bugs": {
    "url": "https://github.com/kalverra/octometrics-action/issues"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "octometrics",
    "metrics",
    "monitoring",
    "visualization",
    "workflow",
    "timing",
    "CPU",
    "memory",
    "disk",
    "IO",
    "GitHub Actions",
    "GitHub Actions timing",
    "GitHub Actions CPU",
    "GitHub Actions memory",
    "GitHub Actions disk",
    "GitHub Actions IO",
    "telemetry",
    "telemetry data",
    "telemetry data visualization",
    "telemetry data monitoring",
    "telemetry data analysis",
    "telemetry data reporting"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rollup --config rollup.config.js",
    "package:watch": "npm run package -- --watch",
    "all": "npm run format:write && npm run lint && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@jest/globals": "^30.3.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "rollup": "^4.59.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
